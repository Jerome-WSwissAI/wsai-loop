{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/hooks/gate-pretool.mjs\"",
        "matcher": "Write|Delete",
        "failClosed": true
      }
    ],
    "stop": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/hooks/stop.mjs\"",
        "loop_limit": 40
      }
    ]
  }
}
