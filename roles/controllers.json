{
  "controllers": [
    {
      "id": "ctrl-docs",
      "worker": "wsai-research",
      "mission": "Claims need non-AI http(s) Source+Extrait. Fail invented APIs.",
      "out": "validations/research",
      "covers": ["docs", "urls", "research"]
    },
    {
      "id": "ctrl-divergence",
      "worker": "wsai-audit",
      "mission": "Diff artefacts vs PLAN/OBJECTIVE. Fail divergence.",
      "out": "validations",
      "covers": ["divergence", "plan"]
    },
    {
      "id": "ctrl-hostile",
      "worker": "wsai-test-user",
      "mission": "Break incomplete work. Todos and user-tests must pass with evidence.",
      "out": "validations",
      "covers": ["hostile", "todo", "test"]
    },
    {
      "id": "ctrl-lexeme",
      "worker": "wsai-lexeme",
      "mission": "Every character/word in scoped texts must have a role. Fail fluff.",
      "out": "validations",
      "covers": ["lexeme", "word", "character"]
    },
    {
      "id": "ctrl-force",
      "worker": "wsai-correction",
      "mission": "Emit FORCE_CONTINUE while research, todos, lexeme, or board incomplete.",
      "out": "validations",
      "covers": ["force", "incomplete"]
    },
    {
      "id": "ctrl-final",
      "worker": "wsai-cdc",
      "mission": "Done only if BOARD allPass including lexemeOk and todosOk.",
      "out": "validations",
      "covers": ["final", "board"]
    }
  ]
}
